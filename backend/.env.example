# Ollami local backend configuration
# Copy this file to .env.local and uncomment lines you want to override.
# .env.local is gitignored; this template is versioned as .env.example.
# Loaded at startup via python-dotenv (override=False — shell env vars take precedence).
# All paths must be absolute; tilde (~) is NOT expanded by dotenv.
# Uncomment and edit a line to override the built-in default.

# ── Ollama ────────────────────────────────────────────────────────────────────
# Base URL for the Ollama OpenAI-compatible API
#OLLAMA_BASE_URL=http://localhost:11434/v1

# Model used for chat and summarisation (must be pulled: ollama pull llama3.2)
#OLLAMA_CHAT_MODEL=llama3.2

# Model used for memory embeddings (must be pulled: ollama pull nomic-embed-text)
#OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Whisper STT ───────────────────────────────────────────────────────────────
# faster-whisper model size: tiny | base | small | medium | large-v3
# Smaller = faster; small is a good balance on Apple Silicon.
#WHISPER_MODEL_SIZE=small

# ── Storage paths ─────────────────────────────────────────────────────────────
# SQLite database file
#DB_PATH=/Users/Shared/.ollami/ollami.db

# Chroma vector store directory
#CHROMA_PATH=/Users/Shared/.ollami/data/chroma

# Uploaded / recorded file storage directory
#STORAGE_PATH=/Users/Shared/.ollami/data/files

# ── TTS (text-to-speech) ──────────────────────────────────────────────────────
# macOS voice name — run `say -v ?` to list all installed voices.
#TTS_VOICE=Samantha

# Speaking rate in words per minute (50–300; 175 is natural pace).
#TTS_RATE=175

# ── Auth ──────────────────────────────────────────────────────────────────────
# Path where the single-user Bearer token is persisted (chmod 600).
# The Swift app reads the same file to authenticate its requests.
#TOKEN_PATH=/Users/Shared/.ollami/token
